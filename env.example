# -----------------------------------------------------------------------------
# Application BASE URL
# https://example.com/docs/env#core-configuration
# For production, set to your domain, e.g. https://example.com
# For development, set to http://localhost:3000 or any other port
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_PAYMENT_PROVIDER="stripe" # 'stripe' or 'creem'

# -----------------------------------------------------------------------------
# Database
# https://example.com/docs/database
# -----------------------------------------------------------------------------
DATABASE_URL=""

# -----------------------------------------------------------------------------
# Better Auth
# https://example.com/docs/auth
# Generate a random string for the secret key using `openssl rand -base64 32`
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=""

# -----------------------------------------------------------------------------
# Github OAuth
# https://example.com/docs/auth#2-configure-github-oauth
# https://www.better-auth.com/docs/authentication/github
# Get Client information from https://github.com/settings/developers
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Google OAuth
# https://example.com/docs/auth#3-configure-google-oauth
# https://www.better-auth.com/docs/authentication/google
# Get Client information from https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Email / Newsletter (Resend)
# https://example.com/docs/email
# https://example.com/docs/newsletter
# Get API key from https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY=""

# -----------------------------------------------------------------------------
# Newsletter (Beehiiv)
# https://example.com/docs/newsletter
# Get API key from https://app.beehiiv.com/settings/integrations
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=""
BEEHIIV_PUBLICATION_ID=""

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2 or S3-compatible service of your choice)
# https://example.com/docs/storage
# Cloudflare R2: https://www.cloudflare.com/developer-platform/products/r2
# -----------------------------------------------------------------------------
STORAGE_REGION="auto"
STORAGE_BUCKET_NAME=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""
STORAGE_PUBLIC_URL=""

# -----------------------------------------------------------------------------
# Payment (Stripe)
# https://example.com/docs/payment
# Get Stripe key and secret from https://dashboard.stripe.com
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Pro plan - monthly subscription
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=""
# Pro plan - yearly subscription
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=""
# Lifetime plan - one-time payment
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=""
# Credit package - basic
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_BASIC=""
# Credit package - standard
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_STANDARD=""
# Credit package - premium
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_PREMIUM=""
# Credit package - enterprise
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_ENTERPRISE=""

# -----------------------------------------------------------------------------
# Payment (Creem)
# https://docs.creem.io/
# Test Mode: set to true to use Creem test environment (serverIdx=1)
# -----------------------------------------------------------------------------
CREEM_API_KEY=""
CREEM_TEST_MODE=false
# Pro plan - monthly subscription (Creem productId)
NEXT_PUBLIC_CREEM_PRODUCT_PRO_MONTHLY=""
# Pro plan - yearly subscription (Creem productId)
NEXT_PUBLIC_CREEM_PRODUCT_PRO_YEARLY=""
# Lifetime plan - one-time payment (Creem productId)
NEXT_PUBLIC_CREEM_PRODUCT_LIFETIME=""
# Credit package - basic (Creem productId)
NEXT_PUBLIC_CREEM_PRODUCT_CREDITS_BASIC=""
# Credit package - standard (Creem productId)
NEXT_PUBLIC_CREEM_PRODUCT_CREDITS_STANDARD=""
# Credit package - premium (Creem productId)
NEXT_PUBLIC_CREEM_PRODUCT_CREDITS_PREMIUM=""
# Credit package - enterprise (Creem productId)
NEXT_PUBLIC_CREEM_PRODUCT_CREDITS_ENTERPRISE=""

# -----------------------------------------------------------------------------
# Configurations
# -----------------------------------------------------------------------------
# Disable image optimization, check out next.config.ts for more details
# -----------------------------------------------------------------------------
DISABLE_IMAGE_OPTIMIZATION=false
# -----------------------------------------------------------------------------
# Run this website as demo website, in most cases, you should set this to false
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_WEBSITE=false
# -----------------------------------------------------------------------------
# Enable credit system (set to true to sell credits outside demo mode)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_CREDITS=false
# -----------------------------------------------------------------------------
# Enable analytics in development mode (for testing)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS_IN_DEV=false

# -----------------------------------------------------------------------------
# Analytics
# https://example.com/docs/analytics
# -----------------------------------------------------------------------------
# Google Analytics (https://analytics.google.com)
# https://example.com/docs/analytics#google
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
# -----------------------------------------------------------------------------
# Umami Analytics (https://umami.is)
# https://example.com/docs/analytics#umami
# -----------------------------------------------------------------------------
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_SCRIPT="https://cloud.umami.is/script.js"
# -----------------------------------------------------------------------------
# OpenPanel Analytics (https://openpanel.dev)
# https://example.com/docs/analytics#openpanel
# -----------------------------------------------------------------------------
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=""
# -----------------------------------------------------------------------------
# Plausible Analytics (https://plausible.io)
# https://example.com/docs/analytics#plausible
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_PLAUSIBLE_SCRIPT="https://plausible.io/js/script.js"
# -----------------------------------------------------------------------------
# Ahrefs Analytics (https://ahrefs.com)
# https://example.com/docs/analytics#ahrefs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AHREFS_WEBSITE_ID=""
# -----------------------------------------------------------------------------
# Seline Analytics
# https://example.com/docs/analytics#seline
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SELINE_TOKEN=""
# -----------------------------------------------------------------------------
# DataFast Analytics (https://datafa.st)
# https://example.com/docs/analytics#datafast
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DATAFAST_WEBSITE_ID=""
NEXT_PUBLIC_DATAFAST_DOMAIN=""
# -----------------------------------------------------------------------------
# PostHog Analytics (https://posthog.com)
# https://example.com/docs/analytics#posthog
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
POSTHOG_API_KEY=""
# -----------------------------------------------------------------------------
# Clarity Analytics (https://clarity.microsoft.com)
# https://example.com/docs/analytics#clarity
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLARITY_PROJECT_ID=""


# -----------------------------------------------------------------------------
# Notification (Discord)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=""
# -----------------------------------------------------------------------------
# Notification (Feishu)
# -----------------------------------------------------------------------------
FEISHU_WEBHOOK_URL=""

# -----------------------------------------------------------------------------
# Affiliate
# https://example.com/docs/affiliate
# -----------------------------------------------------------------------------
# Affonso
# https://affonso.com/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AFFILIATE_AFFONSO_ID=""
# -----------------------------------------------------------------------------
# PromoteKit
# https://www.promotekit.com/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AFFILIATE_PROMOTEKIT_ID=""

# -----------------------------------------------------------------------------
# Captcha (Cloudflare Turnstile)
# https://example.com/docs/captcha
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# -----------------------------------------------------------------------------
# Crisp
# https://example.com/docs/chatbox
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CRISP_WEBSITE_ID=""

# -----------------------------------------------------------------------------
# Credit distribution via Cron Jobs
# https://example.com/docs/cronjobs
# -----------------------------------------------------------------------------
CRON_JOBS_USERNAME=""
CRON_JOBS_PASSWORD=""

# -----------------------------------------------------------------------------
# AI
# https://example.com/docs/ai
# -----------------------------------------------------------------------------
AI_GATEWAY_API_KEY=""
FAL_API_KEY=""
FIREWORKS_API_KEY=""
OPENAI_API_KEY=""
# OpenAI-compatible base URL.
# Leave empty to use official OpenAI endpoint.
# Example relay endpoint:
# OPENAI_BASE_URL="https://api.xxxx.com"
# Note: If your relay requires /v1 suffix, include it explicitly.
OPENAI_BASE_URL=""
REPLICATE_API_TOKEN=""
GOOGLE_GENERATIVE_AI_API_KEY=""
DEEPSEEK_API_KEY=""
OPENROUTER_API_KEY=""

# AI Usage / Credits Billing
# Default false keeps /api/ai/chat in audit-only mode with no credits mutation.
AI_CREDITS_BILLING_ENABLED=false

# AI Embedding Provider (for Knowledge/RAG)
# Provider: 'openai' (default) or other supported providers
AI_EMBEDDING_PROVIDER="openai"
# Knowledge/RAG embeddings use OPENAI_API_KEY and OPENAI_BASE_URL above.
# AI_EMBEDDING_MODEL controls the embedding model.
# The relay endpoint must support OpenAI-compatible /v1/embeddings.
# Embedding model: 'text-embedding-3-small' (default) or other models
AI_EMBEDDING_MODEL="text-embedding-3-small"

# -----------------------------------------------------------------------------
# Web Content Analyzer (Firecrawl)
# https://firecrawl.dev/
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=""

# -----------------------------------------------------------------------------
# Env validation
# Set to true only for CI/build environments that do not have real secrets.
# Do not use this in production.
# -----------------------------------------------------------------------------
SKIP_ENV_VALIDATION=false
